includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
        - routes/
        - database/
        - tests/

    level: 6

    ignoreErrors:
        # Laravel framework-specific generic types that are complex to specify
        - '#Method .* return type with generic class Illuminate\\Database\\Eloquent\\Builder does not specify its types#'
        - '#Method .* has parameter .* with generic class Illuminate\\Database\\Eloquent\\Builder but does not specify its types#'
        - '#Method .* return type with generic class Illuminate\\Database\\Eloquent\\Relations\\.* does not specify its types#'
        - '#Method .* has parameter .* with generic class App\\Models\\.* but does not specify its types#'

    excludePaths:
        - vendor/
        - storage/
        - bootstrap/cache/
        - node_modules/
